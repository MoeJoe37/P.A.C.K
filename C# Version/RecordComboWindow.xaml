<Window x:Class="PACK.RecordComboWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Hotkey" Height="200" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Press the key combination you want to use"
                   Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"/>

        <Border Grid.Row="2" Background="#313244" BorderBrush="#45475A" BorderThickness="1"
                CornerRadius="6" Padding="14,8" MinHeight="40">
            <TextBlock x:Name="ComboDisplay" Text="(press any key…)"
                       Foreground="#CBA6F7" FontSize="14" FontFamily="Consolas"
                       VerticalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="4" x:Name="HintText" Text="Hold modifier keys (Ctrl/Shift/Alt) then press the main key."
                   Foreground="#A6ADC8" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Clear" Width="72" Height="30" Margin="0,0,8,0"
                    Click="Clear_Click"
                    Background="#313244" Foreground="#CDD6F4"
                    BorderBrush="#45475A" BorderThickness="1" Cursor="Hand"/>
            <Button Content="Done" Width="72" Height="30"
                    Click="Done_Click" IsDefault="True"
                    Background="#CBA6F7" Foreground="#1E1E2E"
                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
