<Window x:Class="PACK.ClickOptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Click Step" Height="240" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose click position source"
                   Foreground="#CDD6F4" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI"/>

        <StackPanel Grid.Row="2">
            <RadioButton x:Name="Opt1" Content="Use selected saved position (from Locations tab)"
                         IsChecked="True"
                         Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,10"/>
            <RadioButton x:Name="Opt2" Content="Use current cursor position (capture now)"
                         Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,10"/>
            <RadioButton x:Name="Opt3" Content="Use target window center"
                         Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="72" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click" IsCancel="True"
                    Background="#313244" Foreground="#CDD6F4"
                    BorderBrush="#45475A" BorderThickness="1" Cursor="Hand"/>
            <Button Content="OK" Width="72" Height="30"
                    IsDefault="True" Click="OK_Click"
                    Background="#CBA6F7" Foreground="#1E1E2E"
                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
