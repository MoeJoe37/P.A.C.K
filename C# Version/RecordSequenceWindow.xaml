<Window x:Class="PACK.RecordSequenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Sequence" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="RECORD SEQUENCE" FontSize="10" FontWeight="SemiBold"
                   Foreground="#CBA6F7" FontFamily="Segoe UI"/>

        <!-- Options row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <CheckBox x:Name="RecordWaitsChk" Content="Record timing (waits between actions)"
                      IsChecked="True" Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI"
                      VerticalAlignment="Center" Margin="0,0,18,0"/>
            <TextBlock Text="Min gap (ms):" Foreground="#A6ADC8" FontSize="12"
                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="WaitThresholdTxt" Text="200" Width="60" Height="28"
                     Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                     BorderThickness="1" Padding="6,0" FontSize="12" FontFamily="Segoe UI"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Status row -->
        <Border Grid.Row="4" Background="#1A1030" BorderBrush="#CBA6F7"
                BorderThickness="1" CornerRadius="6" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#F38BA8"
                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="StatusText" Text="Recording… click and type actions now."
                           Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Actions list -->
        <ListBox Grid.Row="6" x:Name="ActionsList"
                 Background="#313244" Foreground="#CDD6F4"
                 BorderBrush="#45475A" BorderThickness="1"
                 FontSize="12" FontFamily="Segoe UI"/>

        <!-- Count + clear row -->
        <Grid Grid.Row="7" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CountLabel" Text="0 actions captured"
                       Foreground="#A6ADC8" FontSize="12" FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
            <Button x:Name="ClearBtn" Grid.Column="1" Content="Clear" Width="70" Height="28"
                    Click="Clear_Click"
                    Background="#3D1A1A" Foreground="#F38BA8"
                    BorderBrush="#6B2A2A" BorderThickness="1" Cursor="Hand"/>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel" Width="90" Height="34"
                    Click="Cancel_Click" IsCancel="True"
                    Background="#313244" Foreground="#CDD6F4"
                    BorderBrush="#45475A" BorderThickness="1" Cursor="Hand"/>

            <Button x:Name="StopDoneBtn" Grid.Column="3" Content="⏹ Stop &amp; Save" Width="130" Height="34"
                    Click="StopDone_Click"
                    Background="#CBA6F7" Foreground="#1E1E2E"
                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
