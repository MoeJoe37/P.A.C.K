<Window x:Class="PACK.SimpleInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="160" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptLabel" Grid.Row="0"
                   Foreground="#CDD6F4" FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 Background="#313244" Foreground="#CDD6F4"
                 BorderBrush="#45475A" BorderThickness="1"
                 Padding="7,0" FontSize="13" FontFamily="Segoe UI" Height="30"
                 VerticalContentAlignment="Center"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="72" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click" IsCancel="True"
                    Background="#313244" Foreground="#CDD6F4"
                    BorderBrush="#45475A" BorderThickness="1" Cursor="Hand"/>
            <Button Content="OK" Width="72" Height="30"
                    Click="OK_Click" IsDefault="True"
                    Background="#CBA6F7" Foreground="#1E1E2E"
                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
